<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cybersecurity Quiz // Jia</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #ff6f9c;
    --pink-soft: #ffe1ec;
    --purple: #9b6bff;
    --purple-soft: #ece3ff;
    --teal: #22c1b4;
    --teal-soft: #d9f9f4;
    --orange: #ff9f43;
    --orange-soft: #fff0dc;
    --yellow: #ffd166;
    --ink: #3a2e4d;
    --muted: #8b7fa3;
    --card: #ffffff;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #fff1f7 0%, #f2ecff 45%, #e3fbf7 100%);
    color: var(--ink);
    font-family: "Quicksand", "Baloo 2", sans-serif;
    display: flex;
    justify-content: center;
    padding: 40px 16px;
  }

  .app-card {
    width: 100%;
    max-width: 640px;
    background: var(--card);
    border-radius: 28px;
    box-shadow: 0 20px 50px rgba(155, 107, 255, 0.16), 0 4px 12px rgba(255, 111, 156, 0.08);
    overflow: hidden;
  }

  .titlebar {
    background: linear-gradient(120deg, var(--pink), var(--purple));
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .titlebar .emoji { font-size: 22px; }

  .titlebar span {
    color: #fff;
    font-family: "Baloo 2", sans-serif;
    font-weight: 700;
    font-size: 16px;
  }

  .screen { padding: 30px 26px; }

  .prompt-line {
    color: var(--purple);
    font-weight: 700;
    font-size: 13px;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  h1 {
    font-family: "Baloo 2", sans-serif;
    font-size: 24px;
    font-weight: 700;
    margin: 8px 0 4px;
    color: var(--ink);
  }

  .subtitle {
    color: var(--muted);
    font-size: 14px;
    margin: 0 0 22px;
    font-weight: 600;
  }

  /* --- Difficulty select screen --- */
  .level-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 18px;
  }

  .level-card {
    border: none;
    border-radius: 18px;
    padding: 16px 18px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .level-card:hover { transform: translateY(-2px) scale(1.01); }

  .level-card .name { font-family: "Baloo 2", sans-serif; font-size: 16px; font-weight: 700; margin: 0 0 2px; }
  .level-card .desc { font-size: 12.5px; margin: 0; opacity: 0.75; font-weight: 600; }
  .level-card .count {
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
    background: rgba(255,255,255,0.6);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .level-card.easy { background: var(--teal-soft); color: #0d8c7f; box-shadow: 0 4px 14px rgba(34,193,180,0.18); }
  .level-card.medium { background: var(--orange-soft); color: #c2760c; box-shadow: 0 4px 14px rgba(255,159,67,0.18); }
  .level-card.hard { background: var(--pink-soft); color: #d13d6b; box-shadow: 0 4px 14px rgba(255,111,156,0.18); }
  .level-card.mixed { background: var(--purple-soft); color: #7440e0; box-shadow: 0 4px 14px rgba(155,107,255,0.18); }

  /* --- Question screen --- */
  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }

  .tag {
    font-size: 11px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .tag-easy { background: var(--teal-soft); color: #0d8c7f; }
  .tag-medium { background: var(--orange-soft); color: #c2760c; }
  .tag-hard { background: var(--pink-soft); color: #d13d6b; }

  .progress {
    display: flex;
    gap: 6px;
    margin-bottom: 22px;
  }

  .progress-dot {
    height: 6px;
    flex: 1;
    background: #f0ebfa;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-dot.done { background: var(--teal); }
  .progress-dot.current { background: var(--yellow); }

  .question {
    font-family: "Baloo 2", sans-serif;
    font-size: 17px;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 20px;
    color: var(--ink);
  }

  .options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .option {
    background: #faf8ff;
    border: 2px solid #f0ebfa;
    color: var(--ink);
    text-align: left;
    padding: 13px 16px;
    border-radius: 14px;
    font-family: inherit;
    font-weight: 600;
    font-size: 14.5px;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.1s ease;
  }

  .option:hover:not(:disabled) {
    border-color: var(--purple);
    background: var(--purple-soft);
    transform: translateX(2px);
  }

  .option:disabled { cursor: default; }

  .option.correct {
    border-color: var(--teal);
    background: var(--teal-soft);
    color: #0d8c7f;
  }

  .option.wrong {
    border-color: var(--pink);
    background: var(--pink-soft);
    color: #d13d6b;
  }

  .feedback {
    margin-top: 16px;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--muted);
    min-height: 20px;
  }

  .next-btn {
    margin-top: 20px;
    background: linear-gradient(120deg, var(--pink), var(--purple));
    color: #fff;
    border: none;
    padding: 12px 22px;
    border-radius: 999px;
    font-family: "Baloo 2", sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    display: none;
    box-shadow: 0 6px 16px rgba(155,107,255,0.28);
  }

  .next-btn.show { display: inline-block; }

  /* --- Results screen --- */
  .result { text-align: center; }

  .result .score {
    font-family: "Baloo 2", sans-serif;
    font-size: 48px;
    background: linear-gradient(120deg, var(--pink), var(--purple));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 12px 0 2px;
    font-weight: 800;
  }

  .result .score-label {
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 18px 0 22px;
  }

  .stat-card {
    background: #faf8ff;
    border-radius: 14px;
    padding: 14px 8px;
  }

  .stat-card .value { font-family: "Baloo 2", sans-serif; font-size: 20px; color: var(--ink); font-weight: 700; }
  .stat-card .label { font-size: 11px; color: var(--muted); margin-top: 2px; font-weight: 600; }

  .bar-track {
    height: 10px;
    background: #f0ebfa;
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 6px;
  }

  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--teal), var(--purple));
    transition: width 0.5s ease;
  }

  .result p.verdict {
    font-size: 14px;
    font-weight: 600;
    margin: 18px 0 24px;
    text-align: center;
    color: var(--ink);
  }

  .action-row {
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  .restart-btn, .change-level-btn {
    padding: 11px 18px;
    border-radius: 999px;
    font-family: "Baloo 2", sans-serif;
    font-weight: 700;
    font-size: 13.5px;
    cursor: pointer;
    border: none;
  }

  .restart-btn {
    background: linear-gradient(120deg, var(--teal), var(--purple));
    color: #fff;
    box-shadow: 0 6px 16px rgba(34,193,180,0.25);
  }

  .change-level-btn {
    background: #faf8ff;
    color: var(--muted);
    border: 2px solid #f0ebfa;
  }

  .change-level-btn:hover { color: var(--purple); border-color: var(--purple-soft); }

  @media (prefers-reduced-motion: no-preference) {
    #screen > * { animation: fadeIn 0.3s ease both; }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
<body>

<div class="app-card">
  <div class="titlebar">
    <span class="emoji">🛡️</span>
    <span>CyberQuiz</span>
  </div>
  <div class="screen" id="screen"></div>
</div>

<script>

  // ---- 1. THE DATA ----
  // Every question has a difficulty level, a shuffled-at-render options
  // list, and the CORRECT ANSWER stored as text (not a position) so
  // shuffling never breaks it.
  const questionBank = {
    easy: [
      {
        question: "What does \"phishing\" mean?",
        options: [
          "A virus that deletes your files",
          "A fake message tricking you into giving up information",
          "A firewall setting",
          "A type of strong password"
        ],
        correct: "A fake message tricking you into giving up information"
      },
      {
        question: "Which of these is the strongest password?",
        options: ["password123", "Karachi2024", "tR!9kLp#2mQz", "12345678"],
        correct: "tR!9kLp#2mQz"
      },
      {
        question: "What is two-factor authentication (2FA)?",
        options: [
          "Using two different passwords",
          "A second verification step, like a code sent to your phone",
          "Logging in twice",
          "A type of antivirus software"
        ],
        correct: "A second verification step, like a code sent to your phone"
      },
      {
        question: "What does HTTPS in a website URL indicate?",
        options: [
          "The site loads faster",
          "The connection between you and the site is encrypted",
          "The site has no ads",
          "The site is owned by Google"
        ],
        correct: "The connection between you and the site is encrypted"
      },
      {
        question: "What's the safest thing to do with an unexpected email attachment from an unknown sender?",
        options: [
          "Open it to see what it is",
          "Forward it to a friend first",
          "Don't open it, and delete or report it",
          "Rename the file before opening"
        ],
        correct: "Don't open it, and delete or report it"
      }
    ],
    medium: [
      {
        question: "You get an email from your \"bank\" asking you to confirm your PIN by replying. What should you do?",
        options: [
          "Reply with the PIN since it's your bank",
          "Ignore it and report or delete it",
          "Forward it to friends to warn them",
          "Click the link to check if it's real"
        ],
        correct: "Ignore it and report or delete it"
      },
      {
        question: "What is a VPN mainly used for?",
        options: [
          "Making your internet connection faster",
          "Encrypting and rerouting your traffic for privacy",
          "Blocking all ads permanently",
          "Backing up your files automatically"
        ],
        correct: "Encrypting and rerouting your traffic for privacy"
      },
      {
        question: "What is \"social engineering\" in cybersecurity?",
        options: [
          "Building secure software architecture",
          "Manipulating people into revealing information or access",
          "A network engineering degree",
          "Designing a company's org chart"
        ],
        correct: "Manipulating people into revealing information or access"
      },
      {
        question: "What's the main purpose of a firewall?",
        options: [
          "To speed up your internet",
          "To monitor and control incoming/outgoing network traffic",
          "To store backup copies of files",
          "To compress large files"
        ],
        correct: "To monitor and control incoming/outgoing network traffic"
      },
      {
        question: "Why is public Wi-Fi risky for online banking?",
        options: [
          "It's usually too slow to load banking sites",
          "Attackers on the same network can potentially intercept your traffic",
          "Banks block public Wi-Fi automatically",
          "It uses too much mobile data"
        ],
        correct: "Attackers on the same network can potentially intercept your traffic"
      }
    ],
    hard: [
      {
        question: "Which practice reduces damage if one of your passwords gets leaked?",
        options: [
          "Using the same password everywhere for consistency",
          "Using a unique password for every account",
          "Writing all passwords in one unprotected text file",
          "Changing your username instead of your password"
        ],
        correct: "Using a unique password for every account"
      },
      {
        question: "What does a SQL injection attack exploit?",
        options: [
          "Weak Wi-Fi encryption",
          "Unsanitized user input passed directly into database queries",
          "Outdated browser plugins",
          "Slow server response times"
        ],
        correct: "Unsanitized user input passed directly into database queries"
      },
      {
        question: "What is the main difference between a virus and a worm?",
        options: [
          "Worms need a host file to spread, viruses don't",
          "Viruses need a host file to attach to; worms self-replicate and spread independently",
          "There is no real difference",
          "Worms only affect mobile devices"
        ],
        correct: "Viruses need a host file to attach to; worms self-replicate and spread independently"
      },
      {
        question: "In a zero-day vulnerability, what does \"zero-day\" refer to?",
        options: [
          "A flaw discovered and exploited before the vendor has released a fix",
          "An attack that takes zero days to plan",
          "A vulnerability that only lasts 24 hours",
          "A bug that causes zero downtime"
        ],
        correct: "A flaw discovered and exploited before the vendor has released a fix"
      },
      {
        question: "What does \"principle of least privilege\" mean in access control?",
        options: [
          "Everyone should have admin access by default",
          "Users/systems should only get the minimum access needed to do their job",
          "Only the least experienced staff need permissions",
          "Privileges should be reviewed once a year"
        ],
        correct: "Users/systems should only get the minimum access needed to do their job"
      }
    ]
  };

  const levels = [
    { key: "easy", name: "Easy", desc: "Core basics — good starting point.", color: "var(--green)" },
    { key: "medium", name: "Medium", desc: "Everyday security judgment calls.", color: "var(--amber)" },
    { key: "hard", name: "Hard", desc: "Terminology and attacker mindset.", color: "var(--red)" },
    { key: "mixed", name: "Mixed", desc: "A random spread across all levels.", color: "var(--blue)" }
  ];

  // ---- 2. STATE ----
  let questions = [];       // the active question set for this run
  let currentIndex = 0;
  let score = 0;
  let streak = 0;
  let bestStreak = 0;
  let answered = false;
  let shuffledOptions = [];
  let selectedLevel = "easy";

  const screen = document.getElementById("screen");

  function shuffle(array) {
    const copy = [...array];
    for (let i = copy.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [copy[i], copy[j]] = [copy[j], copy[i]];
    }
    return copy;
  }

  // ---- HIGH SCORES (localStorage) ----
  // We store one object under a single key, e.g:
  // { easy: 4, medium: 3, hard: 2, mixed: 6 }
  // localStorage only stores strings, so we JSON.stringify() to save
  // and JSON.parse() to read it back as a real object.

  const HIGH_SCORE_KEY = "quizHighScores";

  function getHighScores() {
    const raw = localStorage.getItem(HIGH_SCORE_KEY);
    if (!raw) return {}; // nothing saved yet
    try {
      return JSON.parse(raw);
    } catch (e) {
      return {}; // corrupted data — fail safe instead of crashing
    }
  }

  // Returns true if this run set a NEW high score (so we can show a badge)
  function saveHighScoreIfBetter(levelKey, newScore) {
    const scores = getHighScores();
    const previousBest = scores[levelKey] || 0;
    if (newScore > previousBest) {
      scores[levelKey] = newScore;
      localStorage.setItem(HIGH_SCORE_KEY, JSON.stringify(scores));
      return true;
    }
    return false;
  }

  // ---- 3. RENDER FUNCTIONS ----

  function renderIntro() {
    const highScores = getHighScores();
    screen.innerHTML = `
      <p class="prompt-line">initializing quiz module...</p>
      <h1>Cybersecurity awareness quiz</h1>
      <p class="subtitle">Choose a difficulty to begin.</p>
      <div class="level-grid">
        ${levels.map(lvl => {
          const count = lvl.key === "mixed"
            ? questionBank.easy.length + questionBank.medium.length + questionBank.hard.length
            : questionBank[lvl.key].length;
          const totalForLevel = lvl.key === "mixed" ? 8 : count;
          const best = highScores[lvl.key];
          const bestLabel = best !== undefined ? `best: ${best}/${totalForLevel}` : `${totalForLevel} Qs`;
          return `
            <button class="level-card ${lvl.key}" onclick="startQuiz('${lvl.key}')">
              <div>
                <p class="name" style="color:${lvl.color}">${lvl.name}</p>
                <p class="desc">${lvl.desc}</p>
              </div>
              <span class="count">${bestLabel}</span>
            </button>
          `;
        }).join("")}
      </div>
    `;
  }

  function renderQuestion() {
    answered = false;
    const q = questions[currentIndex];
    shuffledOptions = shuffle(q.options);

    let dotsHtml = "";
    for (let i = 0; i < questions.length; i++) {
      let cls = "progress-dot";
      if (i < currentIndex) cls += " done";
      if (i === currentIndex) cls += " current";
      dotsHtml += `<div class="${cls}"></div>`;
    }

    let optionsHtml = "";
    shuffledOptions.forEach((opt, i) => {
      optionsHtml += `<button class="option" onclick="selectOption(${i})">${opt}</button>`;
    });

    screen.innerHTML = `
      <div class="meta-row">
        <p class="prompt-line">question ${currentIndex + 1} of ${questions.length}</p>
        <span class="tag tag-${q.difficulty}">${q.difficulty}</span>
      </div>
      <div class="progress">${dotsHtml}</div>
      <p class="question">${q.question}</p>
      <div class="options" id="options">${optionsHtml}</div>
      <p class="feedback" id="feedback"></p>
      <button class="next-btn" id="nextBtn" onclick="nextQuestion()">Next &rarr;</button>
    `;
  }

  function renderResult() {
    const pct = Math.round((score / questions.length) * 100);
    let verdict = "Solid instincts. Keep sharpening them.";
    if (pct === 100) verdict = "Perfect score. You'd spot a phishing email in your sleep.";
    else if (pct < 50) verdict = "Worth a review — small habits prevent big breaches.";

    const isNewBest = saveHighScoreIfBetter(selectedLevel, score);
    const bestBadge = isNewBest
      ? `<p style="color: var(--amber); font-size: 12px; margin: 0 0 14px;">&#9733; New high score for ${selectedLevel}!</p>`
      : "";

    screen.innerHTML = `
      <div class="result">
        <p class="prompt-line">quiz complete &middot; ${selectedLevel}</p>
        <p class="score">${score}/${questions.length}</p>
        <p class="score-label">${pct}% correct</p>
        ${bestBadge}
        <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
        <div class="stat-grid">
          <div class="stat-card"><div class="value">${score}</div><div class="label">Correct</div></div>
          <div class="stat-card"><div class="value">${questions.length - score}</div><div class="label">Missed</div></div>
          <div class="stat-card"><div class="value">${bestStreak}</div><div class="label">Best streak</div></div>
        </div>
        <p class="verdict">${verdict}</p>
        <div class="action-row">
          <button class="restart-btn" onclick="startQuiz(selectedLevel)">Retry ${selectedLevel}</button>
          <button class="change-level-btn" onclick="renderIntro()">Change level</button>
        </div>
      </div>
    `;
  }

  // ---- 4. ACTIONS ----

  function buildQuestionSet(levelKey) {
    if (levelKey === "mixed") {
      const all = [
        ...questionBank.easy.map(q => ({ ...q, difficulty: "easy" })),
        ...questionBank.medium.map(q => ({ ...q, difficulty: "medium" })),
        ...questionBank.hard.map(q => ({ ...q, difficulty: "hard" }))
      ];
      return shuffle(all).slice(0, 8);
    }
    return questionBank[levelKey].map(q => ({ ...q, difficulty: levelKey }));
  }

  function startQuiz(levelKey) {
    selectedLevel = levelKey;
    questions = buildQuestionSet(levelKey);
    currentIndex = 0;
    score = 0;
    streak = 0;
    bestStreak = 0;
    renderQuestion();
  }

  function selectOption(selectedIndex) {
    if (answered) return;
    answered = true;

    const q = questions[currentIndex];
    const selectedText = shuffledOptions[selectedIndex];
    const isCorrect = selectedText === q.correct;

    const buttons = document.querySelectorAll("#options .option");
    const feedback = document.getElementById("feedback");
    const nextBtn = document.getElementById("nextBtn");

    buttons.forEach((btn, i) => {
      btn.disabled = true;
      if (shuffledOptions[i] === q.correct) btn.classList.add("correct");
      if (i === selectedIndex && !isCorrect) btn.classList.add("wrong");
    });

    if (isCorrect) {
      score++;
      streak++;
      bestStreak = Math.max(bestStreak, streak);
      feedback.textContent = streak > 1 ? `Correct — streak of ${streak}.` : "Correct.";
      feedback.style.color = "var(--green)";
    } else {
      streak = 0;
      feedback.textContent = "Not quite — the right answer is highlighted above.";
      feedback.style.color = "var(--red)";
    }

    nextBtn.classList.add("show");
  }

  function nextQuestion() {
    currentIndex++;
    if (currentIndex < questions.length) {
      renderQuestion();
    } else {
      renderResult();
    }
  }

  // ---- 5. START ----
  renderIntro();
</script>

</body>
</html>
